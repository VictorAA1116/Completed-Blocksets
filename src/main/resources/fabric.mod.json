			"com.victor.completedblocksets.CompletedBlocksets"
		],
		"fabric-datagen": [
			"com.victor.completedblocksets.CompletedBlocksetsDataGenerator"
		]
	},
	"mixins": [
		"completed-blocksets.mixins.json"
	],
	"depends": {
